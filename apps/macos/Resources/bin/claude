#!/usr/bin/env bash
# remux claude wrapper - injects hooks and session tracking
#
# When running inside a remux terminal (REMUX_SURFACE_ID is set), this wrapper
# intercepts `claude` invocations to inject --session-id and --settings flags
# so that Claude Code hooks fire back into remux for notifications/status.
# Outside remux, it passes through to the real claude binary unchanged.

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    # Honor custom path from Settings > Automation > Claude Code > Claude Binary Path.
    # Guard against self-reference (user pointing back to this wrapper).
    local custom="${REMUX_CUSTOM_CLAUDE_PATH:-}"
    custom="${custom#"${custom%%[![:space:]]*}"}"  # trim leading whitespace
    custom="${custom%"${custom##*[![:space:]]}"}"  # trim trailing whitespace
    if [[ -n "$custom" && -f "$custom" && -x "$custom" ]]; then
        # Use -ef to detect same underlying file even through symlinks
        if [[ ! "$custom" -ef "$0" ]]; then
            printf '%s' "$custom"
            return 0
        fi
    fi
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Return 0 only when REMUX_SOCKET_PATH points to a live remux socket.
remux_socket_available() {
    local socket="${REMUX_SOCKET_PATH:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local self_dir remux_bin
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    remux_bin="$self_dir/remux"
    [[ -x "$remux_bin" ]] || remux_bin="$(command -v remux || true)"
    [[ -n "$remux_bin" ]] || return 1

    # Keep stale/hung socket checks bounded so claude startup does not block
    # behind the CLI default timeout (15s).
    REMUXTERM_CLI_RESPONSE_TIMEOUT_SEC=0.75 \
        "$remux_bin" --socket "$socket" ping >/dev/null 2>&1
}

resolve_hook_remux_bin() {
    local self_dir bundled_cli
    bundled_cli="${REMUX_BUNDLED_CLI_PATH:-}"
    if [[ -n "$bundled_cli" && -x "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    self_dir="$(cd "$(dirname "$0")" && pwd)"
    bundled_cli="$self_dir/remux"
    if [[ -x "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    bundled_cli="$(command -v remux || true)"
    if [[ -n "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    printf '%s' "remux"
}

# Pass through if not in a remux terminal, hooks are disabled, or the remux
# socket is unavailable (stale env / app not running).
IN_REMUX=0
if [[ -n "$REMUX_SURFACE_ID" ]]; then
    IN_REMUX=1
fi

if [[ "$IN_REMUX" == "0" || "$REMUX_CLAUDE_HOOKS_DISABLED" == "1" ]] || ! remux_socket_available; then
    # In remux-launched shells, preserve old behavior and always clear nested
    # Claude session markers, even when we must pass through due to stale socket.
    if [[ "$IN_REMUX" == "1" ]]; then
        unset CLAUDECODE
    fi
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

# Find real claude.
REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

ensure_node_options_restore_module() {
    local guard_dir="${TMPDIR:-/tmp}"
    guard_dir="${guard_dir%/}/remux-claude-node-options"
    local guard_path="$guard_dir/restore-node-options.cjs"
    mkdir -p "$guard_dir" || return 1
    local temp_path
    temp_path="$(mktemp "$guard_dir/restore-node-options.XXXXXX.cjs")" || return 1
    cat >"$temp_path" <<'EOF'
const hadOriginalNodeOptions = process.env.REMUX_ORIGINAL_NODE_OPTIONS_PRESENT === "1";
if (hadOriginalNodeOptions) {
  process.env.NODE_OPTIONS = process.env.REMUX_ORIGINAL_NODE_OPTIONS ?? "";
} else {
  delete process.env.NODE_OPTIONS;
}
delete process.env.REMUX_ORIGINAL_NODE_OPTIONS;
delete process.env.REMUX_ORIGINAL_NODE_OPTIONS_PRESENT;
EOF
    chmod 0644 "$temp_path" || {
        rm -f "$temp_path"
        return 1
    }
    if [[ -f "$guard_path" ]] && cmp -s "$temp_path" "$guard_path"; then
        rm -f "$temp_path" || return 1
    else
        mv -f "$temp_path" "$guard_path" || {
            rm -f "$temp_path"
            return 1
        }
    fi
    printf '%s' "$guard_path"
}

merge_node_options() {
    local guard_path="$1"
    local require_flag="--require=$guard_path"
    local memory_flag="--max-old-space-size=4096"
    local existing="${NODE_OPTIONS:-}"
    local -a filtered=()
    local -a tokens=()
    local token
    local skip_next=0

    if [[ -z "$guard_path" ]]; then
        printf '%s' "$existing"
        return 0
    fi

    read -r -a tokens <<<"$existing"
    for token in "${tokens[@]}"; do
        if (( skip_next )); then
            skip_next=0
            continue
        fi
        if [[ "$token" == "--max-old-space-size" ]]; then
            skip_next=1
            continue
        fi
        if [[ "$token" == --max-old-space-size=* ]]; then
            continue
        fi
        filtered+=("$token")
    done

    if (( ${#filtered[@]} == 0 )); then
        printf '%s %s' "$require_flag" "$memory_flag"
        return 0
    fi
    printf '%s %s' "$require_flag" "$memory_flag"
    printf ' %s' "${filtered[@]}"
}

# Pass through subcommands that don't support session/hook flags.
case "${1:-}" in
    mcp|config|api-key|rc|remote-control) exec "$REAL_CLAUDE" "$@" ;;
esac

# Unset CLAUDECODE to avoid "nested session" detection — remux terminals are
# independent sessions even when the parent shell was launched from Claude Code.
unset CLAUDECODE

# Check if the user already specified a session/resume flag.
# If so, don't inject our own --session-id (it would conflict).
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|-r|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

# Export the wrapper's PID. Because we exec claude below, this PID becomes
# the actual claude process PID, which hooks use for stale-session detection.
export REMUX_CLAUDE_PID=$$
export REMUX_CLAUDE_HOOK_REMUX_BIN="$(resolve_hook_remux_bin)"
if GUARD_PATH="$(ensure_node_options_restore_module)"; then
    if [[ ${NODE_OPTIONS+x} ]]; then
        export REMUX_ORIGINAL_NODE_OPTIONS_PRESENT=1
        export REMUX_ORIGINAL_NODE_OPTIONS="$NODE_OPTIONS"
    else
        export REMUX_ORIGINAL_NODE_OPTIONS_PRESENT=0
        unset REMUX_ORIGINAL_NODE_OPTIONS
    fi
    export NODE_OPTIONS="$(merge_node_options "$GUARD_PATH")"
fi

# Build hooks settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
# - SessionStart/Stop/Notification: existing lifecycle hooks
# - SessionEnd: cleanup when Claude exits (covers Ctrl+C where Stop doesn't fire)
# - UserPromptSubmit: clears "Needs input" and sets "Running" on new prompt
# - PreToolUse: clears "Needs input" when Claude resumes after permission grant (async to avoid latency)
HOOKS_JSON='{"hooks":{"SessionStart":[{"matcher":"","hooks":[{"type":"command","command":"\"${REMUX_CLAUDE_HOOK_REMUX_BIN:-remux}\" claude-hook session-start","timeout":10}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"\"${REMUX_CLAUDE_HOOK_REMUX_BIN:-remux}\" claude-hook stop","timeout":10}]}],"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"\"${REMUX_CLAUDE_HOOK_REMUX_BIN:-remux}\" claude-hook session-end","timeout":1}]}],"Notification":[{"matcher":"","hooks":[{"type":"command","command":"\"${REMUX_CLAUDE_HOOK_REMUX_BIN:-remux}\" claude-hook notification","timeout":10}]}],"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"\"${REMUX_CLAUDE_HOOK_REMUX_BIN:-remux}\" claude-hook prompt-submit","timeout":10}]}],"PreToolUse":[{"matcher":"","hooks":[{"type":"command","command":"\"${REMUX_CLAUDE_HOOK_REMUX_BIN:-remux}\" claude-hook pre-tool-use","timeout":5,"async":true}]}]}}'

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
