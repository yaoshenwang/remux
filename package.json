{
  "name": "remux",
  "version": "0.1.45",
  "description": "Remote terminal multiplexer web client for tmux, zellij, and conpty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaoshenwang/remux.git"
  },
  "bugs": {
    "url": "https://github.com/yaoshenwang/remux/issues"
  },
  "homepage": "https://github.com/yaoshenwang/remux#readme",
  "keywords": [
    "tmux",
    "terminal",
    "remote",
    "mobile",
    "websocket",
    "cloudflared",
    "web-terminal"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "remux": "dist/backend/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "VITE_DEV_MODE=1 tsx watch src/backend/cli.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "build": "npm run build:frontend && npm run build:backend && node -e \"require('fs').utimesSync('dist/backend/cli.js',new Date(),new Date())\"",
    "build:backend": "tsc -p tsconfig.backend.json && node -e \"const fs=require('fs');const s='src/backend/zellij/remux-focus.wasm',d='dist/backend/zellij';fs.mkdirSync(d,{recursive:true});if(fs.existsSync(s))fs.copyFileSync(s,d+'/remux-focus.wasm')\"",
    "build:frontend": "vite build --config vite.config.ts",
    "start": "npm run build && node dist/backend/cli.js",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "test:smoke": "REAL_TMUX_SMOKE=1 vitest run tests/smoke/real-tmux.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "jsdom": "^29.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
