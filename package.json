{
  "name": "remux",
  "version": "0.2.48",
  "description": "Remote workspace cockpit for terminal-first work, powered by the unified runtime-v2 backend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaoshenwang/remux.git"
  },
  "bugs": {
    "url": "https://github.com/yaoshenwang/remux/issues"
  },
  "homepage": "https://github.com/yaoshenwang/remux#readme",
  "keywords": [
    "terminal",
    "remote",
    "mobile",
    "websocket",
    "workspace",
    "runtime-v2",
    "web-terminal"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "remux": "dist/backend/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "VITE_DEV_MODE=1 tsx watch src/backend/cli.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "build": "npm run build:frontend && npm run build:backend && node -e \"require('fs').utimesSync('dist/backend/cli.js',new Date(),new Date())\"",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "vite build --config vite.config.ts",
    "start": "npm run build && node dist/backend/cli.js",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "runtime:install-launchd": "scripts/install-launchd.sh",
    "runtime:load-launchd": "scripts/load-launchd.sh all",
    "runtime:status": "scripts/check-runtime-status.sh all",
    "runtime:sync": "scripts/sync-runtime.sh all --verify-public",
    "runtime:promote-shared": "scripts/sync-runtime.sh dev --verify-public --promote-shared-runtime",
    "native:v2:check": "cargo check --workspace --manifest-path Cargo.toml",
    "native:v2:test": "cargo test --workspace --manifest-path Cargo.toml",
    "native:v2:run": "cargo run --manifest-path Cargo.toml -p remuxd --",
    "runner:install": "scripts/install-github-runner.sh",
    "runner:remove": "scripts/remove-github-runner.sh",
    "runner:status": "scripts/github-runner-status.sh",
    "test:gate": "npm run typecheck && npm test && npm run native:v2:check && npm run build && npm run test:e2e",
    "test:e2e": "npm run build && npm run test:e2e:functional && npm run test:e2e:width",
    "test:e2e:functional": "playwright test tests/e2e/runtime-v2.browser.spec.ts",
    "test:e2e:width": "playwright test tests/e2e/terminal-width.spec.ts",
    "test:e2e:screenshots": "playwright test tests/e2e/screenshot.spec.ts",
    "test:release": "npm run test:gate && npm run test:e2e:screenshots && npm pack --dry-run",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "postinstall": "node scripts/patch-snapfeed.mjs && npm rebuild better-sqlite3",
    "check:terminology": "bash scripts/check-terminology.sh",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@microsoft/snapfeed": "0.1.0",
    "@microsoft/snapfeed-server": "^0.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "jsdom": "^29.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
